<%- include('partials/header') %>
    <main>
        <h1>
            <%= title%>
        </h1>

        <h2>
            <%= organizationDetails.name %>
        </h2>

        <img src="/images/<%= organizationDetails.logo_file %>" alt="Logo of <%= organizationDetails.name %> company">

        <p>
            Description: <%= organizationDetails.description %>
        </p>

        <h3>
            Service Projects Related to Organization
        </h3>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </li>
                <% }) %>
        </ul>

        <section class="edit-organization">
            <a href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization</a>
        </section>
    </main>

    <%- include('partials/footer') %>