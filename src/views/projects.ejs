<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <%= new Date(project.project_date).toLocaleDateString('en-CA', { year: 'numeric' , month: 'short' ,
                        day: 'numeric' }) %>:
                        <strong>
                            <a href="/project/<%=project.organization_id%>">
                                <%= project.title %>
                            </a>
                        </strong>

                        <span>
                            (<a href="/organization/<%=project.organization_id%>">
                                <%= project.name %>
                            </a>)
                        </span>
                </li>
                <%})%>

        </ul>
    </main>
    <%- include('partials/footer') %>