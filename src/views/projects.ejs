<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <%= new Date(project.project_date).toLocaleDateString('en-CA', { year: 'numeric' , month: 'short' ,
                        day: 'numeric' }) %>: <strong>
                            <%= project.title %>
                        </strong> (<%= project.name %>)
                </li>
                <%})%>

        </ul>
    </main>
    <%- include('partials/footer') %>