<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    -
                    <strong>
                        <a href="/project/<%=project.organization_id%>">
                            <%= project.title %>
                        </a>
                    </strong>

                    <span>
                        (<a href="/organization/<%=project.organization_id%>">
                            <%= project.name %>
                        </a>)
                    </span>
                </li>
                <%})%>

        </ul>
    </main>
    <%- include('partials/footer') %>