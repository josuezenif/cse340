<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= categoryDetails.category_name %>
        </h2>

        <h3>
            Projects
        </h3>

        <ul>
            <% projectsList.forEach(project=> { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include('partials/footer') %>