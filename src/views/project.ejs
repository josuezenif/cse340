<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= project_details.title %>
        </h2>

        <p>
            <strong>Short description: </strong>
            <%= project_details.description %>
        </p>

        <p>
            <strong>Project Date: </strong>
            <%- new Date(project_details.project_date).toLocaleDateString('en-CA', { year: 'numeric' , month: 'short' ,
                day: 'numeric' });%>
        </p>

        <p>
            <strong>Location: </strong>
            <%= project_details.project_location %>
        </p>

        <p>
            <strong>Organization: </strong>
            <a href="/organization/<%=project_details.organization_id%>">
                <%= project_details.name %>
            </a>
        </p>

        <p>
            <strong>Categories: </strong>
            <% categories.forEach(category=> { %>
                - <a href="/category/<%= category.category_id %>">
                    <%= category.category_name %>
                </a>
                <% }) %>

        </p>

        <p>
            <a href="/project/<%= project_details.project_id %>/assign-categories">Edit Categories</a>
        </p>


    </main>

    <%- include('partials/footer') %>