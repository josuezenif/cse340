<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= projectDetails.title %>
        </h2>

        <form action="/project/<%= projectId %>/assign-categories" method="POST">

            <div class="form-group">
                <% categories.forEach(category=> { %>
                    <div>
                        <input type="checkbox" id="category-<%= category.category_id %>" name="categoryIds"
                            value="<%= category.category_id %>">

                        <label for="category-<%= category.category_id %>">
                            <%= category.category_name %>
                        </label>
                    </div>
                    <% }); %>
            </div>
            <button type="submit">Update Categories</button>
        </form>
    </main>
    <%- include('partials/footer') %>