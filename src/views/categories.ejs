<%- include('partials/header') %>

    <main>
        <h1>
            <%- title %>
        </h1>

        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.category_name %>
                    </a>
                </li>
                <%})%>
        </ul>

        <p>
            <a href="/new-category">Add new category</a>
        </p>

    </main>

    <%- include('partials/footer') %>