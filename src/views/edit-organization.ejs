<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <form action="/edit-organization/<%= organization.organization_id %>" method="POST">
            <div class="form-group">
                <label for="name">Organization Name</label>
                <input type="text" id="name" name="name" value="<%= organization.name %>" required maxlength="150">
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" required
                    maxlength="500"><%= organization.description %></textarea>
            </div>

            <div class="form-group">
                <label for="email">Contact Email</label>
                <input type="email" id="email" name="email" value="<%= organization.email %>" required>
            </div>

            <div class="form-group">
                <label for="logo_file">Logo Filename</label>
                <input type="text" id="logo_file" name="logo_file" value="<%= organization.logo_file %>">
            </div>

            <button type="submit">Update Organization</button>
        </form>

    </main>
    <%- include('partials/footer') %>